# This template lists runtime values the site expects in each environment.
# It is separate from code so deployment configuration can change without code edits.
# Content adapters, SEO metadata, and analytics wiring all read these values.

NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com
NEXT_PUBLIC_SUBSTACK_URL=https://example.substack.com
NEXT_PUBLIC_EMAIL=hello@example.com
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@example
SUBSTACK_FEED_URL=https://example.substack.com/feed
YOUTUBE_FEED_URL=https://www.youtube.com/feeds/videos.xml?channel_id=CHANNEL_ID
