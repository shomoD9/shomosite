NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=https://www.youtube.com/@armchairdescending
NEXT_PUBLIC_GITHUB_URL=https://github.com/shomoD9/shomosite
SUBSTACK_FEED_URL=https://ds013.substack.com/feed
